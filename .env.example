# Clé Google Cloud unique (recommandé) — PageSpeed Insights + Places API (New) si la même clé est autorisée pour les deux.
GOOGLE_API_KEY=

# Sinon, clés séparées (optionnel si GOOGLE_API_KEY est défini) :
# GOOGLE_PAGESPEED_API_KEY=
# GOOGLE_PLACES_API_KEY=

# Sans aucune clé PageSpeed : scores simulés. Sans clé Places : concurrents simulés.
# Activer sur le projet GCP : PageSpeed Insights API + Places API (New). Facturation requise côté Google.

# Capture d’écran (Puppeteer) — si Chromium intégré échoue sous Windows, pointez vers Chrome :
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# (ou PUPPETEER_EXECUTABLE_PATH avec le même chemin)
